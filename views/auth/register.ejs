<%- include('../partials/header.ejs') %>

<main class="container max-w-md mx-auto py-24">
  <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
    <h1 class="text-3xl font-bold text-center text-white mb-2">Register</h1>
    <p class="text-center text-gray-400 mb-8">Signing in MDB</p>


    <form action="/auth/register" method="POST">
      <div class="mb-4">
        <label for="fullname" class="block text-white/80 text-sm font-medium mb-2">Full name</label>
        <input 
          type="text" 
          id="fullname" 
          name="fullname" 
          required
          class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-white"
          placeholder="full name"
        >
      </div>

      <div class="mb-4">
        <label for="email" class="block text-white/80 text-sm font-medium mb-2">Email</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required
          class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-white"
          placeholder="example@email.com"
        >
      </div>

      <div class="mb-6">
        <label for="password" class="block text-white/80 text-sm font-medium mb-2">Password</label>
        <input 
          type="password" 
          id="password" 
          name="password" 
          required
          minlength="6"
          class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-white"
          placeholder="at least 6 carachter"
        >
      </div>

      <button 
        type="submit" 
        class="w-full bg-primary text-white font-medium py-3 rounded-lg transition-all"
      >
        Register
      </button>
    </form>

    <div class="mt-6 text-center text-sm text-gray-400">
      Do already have account?
      <a href="/auth/login" class="text-blue-400 hover:text-blue-300 transition">Enter</a>
    </div>
  </div>
</main>

<%- include('../partials/footer.ejs') %>
