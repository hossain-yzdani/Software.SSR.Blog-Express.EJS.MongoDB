<%- include('../partials/header.ejs') %>

<main class="container mx-auto px-4 my-28 max-w-4xl">
  <!-- Header -->
  <div class="flex justify-between items-center mb-8 p-6 bg-gradient-to-r from-gray-800/50 to-gray-900/50 rounded-xl border border-gray-700 backdrop-blur-sm">
    <div>
      <h1 class="text-3xl font-bold text-primary">
        Edit Post
      </h1>
      <p class="text-gray-400 text-sm mt-1">Update your blog content</p>
    </div>
    <a href="/admin" class="flex items-center gap-2 text-gray-400 hover:text-white transition duration-200">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Dashboard
    </a>
  </div>

  <!-- Form -->
  <div class="bg-gray-900/50 rounded-xl border border-gray-700 p-6 md:p-8 backdrop-blur-sm">
    <form action="/blog/<%= blog.slug %>" method="POST" class="space-y-6">
      <!-- Title -->
      <div>
        <label class="block text-gray-300 font-medium mb-2">Title</label>
        <input 
          type="text" 
          name="title" 
          value="<%= blog.title %>" 
          required 
          class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white transition duration-200"
          placeholder="Enter post title"
        >
      </div>

      <!-- Slug -->
      <div>
        <label class="block text-gray-300 font-medium mb-2">Slug (URL)</label>
        <input 
          type="text" 
          name="slug" 
          value="<%= blog.slug %>" 
          required 
          class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white transition duration-200"
          placeholder="my-awesome-post"
        >
        <p class="text-gray-500 text-xs mt-1">Unique identifier for the post URL</p>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-gray-300 font-medium mb-2">Description</label>
        <textarea 
          name="description" 
          rows="3" 
          class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white transition duration-200 resize-none"
          placeholder="Short description for SEO and previews"
        ><%= blog.description %></textarea>
      </div>

      <!-- Content -->
      <div>
        <label class="block text-gray-300 font-medium mb-2">Content</label>
        <textarea 
          name="content" 
          rows="12" 
          class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white transition duration-200 font-mono text-sm"
          placeholder="Write your blog content here..."
        ><%= blog.content %></textarea>
      </div>

      <!-- Image fields (commented - ready to uncomment if needed) -->
      <!-- <% if (blog.imgUrl) { %>
        <div class="border-t border-gray-700 pt-4 mt-4">
          <p class="text-gray-500 text-sm mb-4">Image fields (optional)</p>
          <div class="space-y-4">
            <div>
              <label class="block text-gray-300 font-medium mb-2">Image URL</label>
              <input 
                type="text" 
                name="imgUrl" 
                value="<%= blog.imgUrl %>" 
                class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white"
              >
            </div>
            <div>
              <label class="block text-gray-300 font-medium mb-2">Image Alt Text</label>
              <input 
                type="text" 
                name="imgAlt" 
                value="<%= blog.imgAlt %>" 
                class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white"
              >
            </div>
          </div>
        </div>
      <% } %> -->

      <!-- Form Actions -->
      <div class="flex gap-4 pt-4 border-t border-gray-700">
        <button 
          type="submit" 
          class="flex items-center gap-2 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white px-6 py-2 rounded-lg transition duration-200 shadow-lg shadow-blue-500/20"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
          Update Post
        </button>
        
        <a 
          href="/admin" 
          class="flex items-center gap-2 bg-gray-700/50 hover:bg-gray-700 text-gray-300 px-6 py-2 rounded-lg transition duration-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          Cancel
        </a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer.ejs') %>