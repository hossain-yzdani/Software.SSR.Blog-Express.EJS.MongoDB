<%- include('../partials/header.ejs') %>

<main class="container mx-auto px-4 my-28 max-w-6xl">
  <!-- Header -->
  <div class="flex justify-between items-center mb-8 p-6 bg-gradient-to-r from-gray-800/50 to-gray-900/50 rounded-xl border border-gray-700 backdrop-blur-sm">
    <div>
      <h1 class="text-3xl font-bold text-primary">
        Admin Panel
      </h1>
      <p class="text-gray-400 text-sm mt-1">Manage users and blog posts</p>
    </div>
    <a href="/admin/logout" class="flex items-center gap-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 px-4 py-2 rounded-lg transition duration-200 border border-red-500/20">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Logout
    </a>
  </div>

  <!-- Users Section -->
  <section class="mb-10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-1 h-6 bg-blue-500 rounded-full"></div>
      <h2 class="text-xl font-semibold text-white">Users</h2>
      <span class="bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full text-xs font-medium"><%= users.length %></span>
    </div>
    
    <div class="bg-gray-900/50 rounded-xl border border-gray-700 overflow-hidden backdrop-blur-sm">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-800/50 border-b border-gray-700">
            <th class="text-left p-4 text-gray-300 font-medium">Email</th>
            <th class="text-left p-4 text-gray-300 font-medium">Role</th>
            <th class="text-left p-4 text-gray-300 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
            <tr class="border-b border-gray-800 hover:bg-gray-800/30 transition duration-150">
              <td class="p-4 text-gray-200"><%= user.email %></td>
              <td class="p-4">
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= user.role === 'admin' ? 'bg-purple-500/20 text-purple-400' : 'bg-gray-500/20 text-gray-400' %>">
                  <%= user.role %>
                </span>
              </td>
              <td class="p-4">
                <a href="/admin/users/delete/<%= user._id %>" 
                   onclick="return confirm('Are you sure you want to delete this user?')" 
                   class="text-red-400 hover:text-red-300 transition duration-150 flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                  Delete
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Blogs Section -->
  <section class="mb-10">
    <div class="flex justify-between items-center mb-4">
      <div class="flex items-center gap-3">
        <div class="w-1 h-6 bg-green-500 rounded-full"></div>
        <h2 class="text-xl font-semibold text-white">Blog Posts</h2>
        <span class="bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full text-xs font-medium"><%= blogs.length %></span>
      </div>
      <a href="/admin/blogs/new" class="flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg transition duration-200 shadow-lg shadow-green-500/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        New Blog
      </a>
    </div>
    
    <div class="bg-gray-900/50 rounded-xl border border-gray-700 overflow-hidden backdrop-blur-sm">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-800/50 border-b border-gray-700">
            <th class="text-left p-4 text-gray-300 font-medium">Title</th>
            <th class="text-left p-4 text-gray-300 font-medium">Slug</th>
            <th class="text-left p-4 text-gray-300 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% blogs.forEach(blog => { %>
            <tr class="border-b border-gray-800 hover:bg-gray-800/30 transition duration-150">
              <td class="p-4 text-gray-200 font-medium"><%= blog.title %></td>
              <td class="p-4 text-gray-400 text-sm"><%= blog.slug %></td>
              <td class="p-4">
                <div class="flex gap-3">
                  <a href="/admin/blogs/edit/<%= blog.slug %>" 
                     class="text-blue-400 hover:text-blue-300 transition duration-150 flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit
                  </a>
                  <button href="/blog/<%= blog.slug %>" 
                     onclick="deletePost('<%= blog.slug %>')" 
                     class="text-red-400 hover:text-red-300 transition duration-150 flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include('../partials/footer.ejs') %>

<script>
  function deletePost(id) {
  if (confirm("Are you sure?")) {
    fetch(`/blog/${id}`, {
      method: "DELETE",
      headers: {
        "Content-Type": "application/json",
      },
    })
      .then((res) => res.redirect('/'))
      .then((data) => {
        if (data.success) location.reload();
        else alert("Error!");
      });
  }
}
</script>