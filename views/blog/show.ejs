<%- include('../partials/header.ejs') %>

<main class="container max-w-4xl mx-auto mt-28">
  <article>
    <h1 class="text-3xl font-bold text-primary"><%= blog.title %></h1>
    <div class="text-gray text-sm mt-2">
      <%= blog.createdAt.toLocaleDateString('en-US') %><%= blog.author %>
    </div>

    <% if (blog.imgUrl) { %>
      <!-- <img src="<%= blog.imgUrl %>" alt="<%= blog.imgAlt || blog.title %>" class="w-full rounded-xl my-5"> -->
    <% } %>

    <div class="text-gray leading-relaxed post-content">
      <%- blog.content %>
    </div>

    <div class="mt-8 pt-4 border-t">
      <a href="/" class="text-primary">← Back to all posts</a>
    </div>
  </article>
</main>

<%- include('../partials/footer.ejs') %>