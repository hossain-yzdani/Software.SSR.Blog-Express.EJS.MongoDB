<%- include('../partials/header.ejs') %>

<main class="container">
  <section class="hero text-center mb-4 py-10">
    <h1 class="text-4xl font-bold text-primary">Modern Dev Blog</h1>
    <p class="text-gray mt-2">Thoughts on coding, design, and building things.</p>
  </section>

  <section class="mt-4">
    <h2 class="text-2xl font-bold mb-4">Latest Posts</h2>
    <div class="grid">
      <% posts.forEach(post => { %>
        <div class="card mb-4">
          <h3><a href="/blog/<%= post.slug %>" class="text-primary"><%= post.title %></a></h3>
          <div class="text-gray text-sm"><%= post.createdAt.toDateString() %></div>
          <p class="text-gray mt-2"><%= post.description %></p>
          <a href="/blog/<%= post.slug %>" class="text-primary mt-2 inline-block">Read more →</a>
        </div>
      <% }) %>
    </div>
  </section>
</main>

<%- include('../partials/footer.ejs') %>