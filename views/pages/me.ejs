<%- include('../partials/header.ejs') %>

<main class="container max-w-5xl mx-auto px-4 py-12">
  <!-- Header -->
  <div class="text-center my-16">
    <h1 class="text-3xl font-bold text-primary">My Account</h1>
    <p class="text-gray mt-2">Manage your profile and settings</p>
  </div>

  <div class="grid md:grid-cols-4 gap-8">
    <!-- Sidebar -->
    <div class="md:col-span-1">
      <div class="bg-card rounded-xl p-5 border">
        <div class="text-center mb-5">
          <div class="w-20 h-20 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-white font-semibold"><%= user?.fullname || 'Guest User' %></h3>
          <p class="text-gray text-sm"><%= user?.email || 'user@example.com' %></p>
        </div>

        <nav class="flex flex-col gap-2">
          <a href="/me" class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary/10 text-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span >Profile</span>
          </a>
          <!-- <a href="/me/orders" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition">
            <svg class="w-4 h-4" fill="none" stroke="white" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span style="color: white;">My Orders</span>
          </a>
          <a href="/me/settings" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition">
            <svg class="w-4 h-4" fill="none" stroke="white" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1。
          </a> -->
          <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-red-500/10 text-red-400 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span>Logout</span>
          </a>
        </nav>
      </div>
    </div>

    <!-- Main Content - Profile -->
    <div class="md:col-span-3">
      <div class="bg-card rounded-xl p-6 md:p-8 border">
        <h2 class="text-2xl font-bold text-white mb-6">Profile Information</h2>
        
        <form action="/auth/update" method="POST" class="space-y-5">
          <div class="grid md:grid-cols-2 gap-5">
            <div>
              <label class="block text-gray text-sm font-medium mb-2">Full Name</label>
              <input 
                type="text" 
                name="fullname" 
                value="<%= user?.fullname || '' %>" 
                class="w-full px-4 py-2 bg-dark border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-white"
              >
            </div>
            <div>
              <label class="block text-gray text-sm font-medium mb-2">Email Address</label>
              <input 
                type="email" 
                name="email" 
                value="<%= user?.email || '' %>" 
                class="w-full px-4 py-2 bg-dark border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-white"
              >
            </div>
          </div>
          
          <div>
            <label class="block text-gray text-sm font-medium mb-2">Bio</label>
            <textarea 
              name="bio" 
              rows="4" 
              class="w-full px-4 py-2 bg-dark border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-white resize-none"
              placeholder="Tell us a little about yourself..."
            ><%= user?.bio || '' %></textarea>
          </div>
          
          <div class="flex justify-end">
            <button type="submit" class="btn btn-primary bg-primary text-white px-6 py-2 rounded-lg hover:bg-primary-dark transition">
              Save Changes
            </button>
          </div>
        </form>

        <div class="border-t border-gray-700 mt-8 pt-6">
          <h3 class="text-lg font-semibold text-white mb-4">Change Password</h3>
          <form action="/auth/update-password" method="POST" class="space-y-4">
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label class="block text-gray text-sm font-medium mb-2">New Password</label>
                <input 
                  type="password" 
                  name="newPassword" 
                  class="w-full px-4 py-2 bg-dark border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-white"
                  placeholder="••••••••"
                >
              </div>
              <div>
                <label class="block text-gray text-sm font-medium mb-2">Confirm Password</label>
                <input 
                  type="password" 
                  name="confirmPassword" 
                  class="w-full px-4 py-2 bg-dark border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-white"
                  placeholder="••••••••"
                >
              </div>
            </div>
            <div class="flex justify-end">
              <button type="submit" class="btn btn-outline border border-primary text-primary px-6 py-2 rounded-lg hover:bg-primary/10 transition">
                Update Password
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer.ejs') %>