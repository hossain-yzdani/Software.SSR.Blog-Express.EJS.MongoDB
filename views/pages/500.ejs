<%- include('../partials/header.ejs') %>

<main class="container min-h-screen flex items-center justify-center">
  <div class="text-center py-16">
    <div class="text-9xl font-bold text-red-300 mb-4">500</div>
    <h1 class="text-3xl font-bold text-gray-800 mb-2">Internal Server Error</h1>
    <p class="text-gray-600 mb-4">Something went wrong on our end. Please try again later.</p>
    <p class="text-sm text-gray-500 mb-8">Our team has been notified. Sorry for the inconvenience!</p>
    <div class="space-x-4">
      <a href="/" class="bg-blue-500 text-white px-6 py-3 rounded-lg hover:bg-blue-600 transition">
        ← Back to Home
      </a>
      <button onclick="location.reload()" class="bg-gray-500 text-white px-6 py-3 rounded-lg hover:bg-gray-600 transition">
        Try Again ↻
      </button>
    </div>
  </div>
</main>

