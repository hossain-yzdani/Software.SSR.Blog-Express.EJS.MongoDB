<%- include('../partials/header.ejs') %>

<!-- Hero Section -->
<section class="hero text-center my-16">
  <h1 class="text-4xl font-bold text-primary">Contact Us</h1>
  <p class="text-gray text-lg mt-4 max-w-2xl mx-auto px-4">
    Have a question or just want to say hi? We'd love to hear from you.
  </p>
</section>

<!-- دو ستونه - فرم در سمت راست، متن سمت چپ -->
<section class="container px-4">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- سمت چپ: متن و شبکه‌های اجتماعی -->
      <div class="order-2 lg:order-1">
        <div class="card rounded-xl p-6 md:p-8 border h-full flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-bold text-white mb-4">Let's Talk</h2>
            <p class="text-gray-light leading-relaxed mb-6">
              Whether you have a question about our blog, want to collaborate, 
              or just want to say hello — we're all ears. Fill out the form 
              and we'll get back to you as soon as possible.
            </p>
            
            <div class="border-t border-gray-700 my-6"></div>
            
            <h3 class="text-lg font-semibold text-white mb-4">Connect with us</h3>
            
            <!-- شبکه‌های اجتماعی -->
            <div class="grid grid-cols-2 gap-4">
              
              <a href="mailto:hello@blog.com" class="social-card flex items-center gap-3 p-3 rounded-xl bg-dark border border-gray-700 hover:border-primary transition group">
                <div class="social-icon email-icon">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-gray">Email</div>
                  <div class="text-sm text-white">hello@blog.com</div>
                </div>
              </a>
              
              <a href="#" class="social-card flex items-center gap-3 p-3 rounded-xl bg-dark border border-gray-700 hover:border-primary transition group">
                <div class="social-icon github-icon">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.21.68-.48 0-.24-.01-.88-.01-1.72-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1.01.07 1.54 1.04 1.54 1.04.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.64-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.26.1-2.62 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.33.85 0 1.7.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.36.2 2.37.1 2.62.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .27.18.58.69.48C19.13 20.17 22 16.42 22 12c0-5.52-4.48-10-10-10z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-gray">GitHub</div>
                  <div class="text-sm text-white">github.com/user</div>
                </div>
              </a>
              
              <a href="#" class="social-card flex items-center gap-3 p-3 rounded-xl bg-dark border border-gray-700 hover:border-primary transition group">
                <div class="social-icon twitter-icon">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 20l10-10m0 0v7m0-7h-7" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-gray">Twitter</div>
                  <div class="text-sm text-white">@username</div>
                </div>
              </a>
              
              <a href="#" class="social-card flex items-center gap-3 p-3 rounded-xl bg-dark border border-gray-700 hover:border-primary transition group">
                <div class="social-icon linkedin-icon">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C0.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451c.979 0 1.771-.773 1.771-1.729V1.729C24 .774 23.204 0 22.225 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-gray">LinkedIn</div>
                  <div class="text-sm text-white">linkedin.com/in/user</div>
                </div>
              </a>
              
            </div>
          </div>
          
          <!-- <div class="mt-6 p-4 rounded-xl bg-primary/5 border border-primary/20">
            <div class="flex items-center gap-3 w-8 h-8">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <div class="text-sm text-gray">Response time</div>
                <div class="text-white font-semibold">Usually within 24 hours</div>
              </div>
            </div>
          </div> -->
        </div>
      </div>
      
      <!-- سمت راست: فرم تماس -->
      <div class="order-1 lg:order-2">
        <div class="card rounded-xl p-6 md:p-8 border">
          <h2 class="text-2xl font-bold text-white mb-6">Send us a message</h2>
          
          <form action="/contact" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div class="form-group">
                <label class="text-gray text-sm font-medium mb-2 block">Full Name</label>
                <input type="text" name="name" required class="w-full px-4 py-2.5 bg-dark border border-gray-700 rounded-lg focus:border-primary focus:outline-none transition text-white" placeholder="John Doe">
              </div>
              
              <div class="form-group">
                <label class="text-gray text-sm font-medium mb-2 block">Email Address</label>
                <input type="email" name="email" required class="w-full px-4 py-2.5 bg-dark border border-gray-700 rounded-lg focus:border-primary focus:outline-none transition text-white" placeholder="john@example.com">
              </div>
            </div>
            
            <div class="form-group mb-4">
              <label class="text-gray text-sm font-medium mb-2 block">Subject</label>
              <input type="text" name="subject" required class="w-full px-4 py-2.5 bg-dark border border-gray-700 rounded-lg focus:border-primary focus:outline-none transition text-white" placeholder="What's this about?">
            </div>
            
            <div class="form-group mb-6">
              <label class="text-gray text-sm font-medium mb-2 block">Message</label>
              <textarea name="message" rows="5" required class="w-full px-4 py-2.5 bg-dark border border-gray-700 rounded-lg focus:border-primary focus:outline-none transition text-white resize-none" placeholder="Tell us what's on your mind..."></textarea>
            </div>
            
            <button type="submit" class="w-full btn btn-primary bg-primary hover:bg-primary-dark text-white font-semibold py-3 rounded-lg transition-all duration-300 transform hover:scale-[1.02]">
              Send Message
            </button>
          </form>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  /* اضافه کردن استایل‌های جدید */
  .social-card {
    transition: all 0.25s ease;
  }
  
  .social-card:hover {
    border-color: #3b82f6;
    transform: translateY(-2px);
  }
  
  .social-icon {
    width: 40px;
    height: 40px;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3b82f6;
  }
  
  .social-card:hover .social-icon {
    background: #3b82f6;
    color: white;
  }
  
  /* بهبود ریسپانسیو */
  @media (max-width: 768px) {
    .grid-cols-2 {
      gap: 12px;
    }
    
    .social-card {
      padding: 12px;
    }
    
    .social-icon {
      width: 36px;
      height: 36px;
    }
  }
</style>

<%- include('../partials/footer.ejs') %>